{
  "name": "srfibergo",
  "version": "1.0.6",
  "description": "CLI to scaffold Go + Fiber web projects with Tailwind CSS, Font Awesome, hot reload (Air), .env support, MongoDB integration and Docker deploy. Generate a full-stack Go project in seconds.",
  "main": "bin/cli.js",
  "bin": {
    "srfibergo": "bin/cli.js"
  },
  "files": [
    "bin",
    "README.md"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "link": "npm link",
    "unlink": "npm unlink",
    "build": "npx pkg . --targets node18-linux --output srfibergo"
  },
  "keywords": [
    "go",
    "golang",
    "fiber",
    "go-fiber",
    "gofiber",
    "cli",
    "scaffold",
    "generator",
    "boilerplate",
    "starter",
    "template",
    "tailwind",
    "tailwindcss",
    "font-awesome",
    "web",
    "fullstack",
    "backend",
    "http",
    "server",
    "air",
    "hot-reload",
    "godotenv",
    "mongodb",
    "mongo",
    "docker",
    "docker-compose",
    "vps",
    "deploy",
    "create-app"
  ],
  "author": "SrTermax <github.com/SrTermax>",
  "license": "MIT",
  "homepage": "https://github.com/SrTermax/srfibergo#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/SrTermax/srfibergo.git"
  },
  "bugs": {
    "url": "https://github.com/SrTermax/srfibergo/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.6"
  }
}
